# Kiro 账号管理平台 v2 — 环境变量示例
#
# ⚠️ 安全基线：本文件刻意【不包含】AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY。
#    AWS 凭证一律由运行环境的 IAM Role 提供（ECS Task Role / EKS IRSA / EC2 Instance Profile）。
#    本地开发时用 `aws sso login` 或 AWS_PROFILE 走默认凭证链，同样无需在此填密钥。

# ---- AWS 资源标识（非密）----
AWS_REGION=us-east-1
IDENTITY_STORE_ID=d-xxxxxxxxxx
SSO_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxx
KIRO_SIGN_IN_URL=https://d-xxxxxxxxxx.awsapps.com/start
KIRO_GROUP_NAME=Q

# ---- DynamoDB 映射表 ----
MAPPING_TABLE_NAME=kiro-account-mapping
MAPPING_GSI_NAME=feishu_open_id-index

# ---- 账号配额 ----
DEFAULT_ACCOUNT_QUOTA=2

# ---- 飞书 ----
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_REDIRECT_URI=http://your-domain/api/auth/feishu/callback
ADMIN_OPEN_IDS=ou_xxx,ou_yyy

# ---- Web ----
JWT_SECRET=change-me-to-a-random-string
FRONTEND_URL=http://localhost:5173
