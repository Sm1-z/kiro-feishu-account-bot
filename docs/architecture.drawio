<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="Kiro账号管理平台-架构" id="kiro-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title ===== -->
        <mxCell id="title" value="Kiro 账号自助管理平台 — 架构图 / Kiro Self-Service Account Platform" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="飞书 OAuth 登录 + Web 自助申请 + 飞书卡片审批（免公网 WS 长连接）→ 自动开通 → DynamoDB 映射（UserId 锚点）" style="text;html=1;fontSize=12;align=center;verticalAlign=middle;fillColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="900" height="24" as="geometry" />
        </mxCell>

        <!-- ===== Lane: 用户 / 飞书 ===== -->
        <mxCell id="lane_user" value="① 用户 &amp; 飞书 / User &amp; Feishu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="280" height="430" as="geometry" />
        </mxCell>
        <mxCell id="user" value="申请人 / Applicant&#10;（飞书账号 / Feishu user）" style="shape=umlActor;verticalLabelPosition=bottom;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="40" height="80" as="geometry" />
        </mxCell>
        <mxCell id="admin" value="审批人 / Approver&#10;（飞书手机端可批 / mobile）" style="shape=umlActor;verticalLabelPosition=bottom;html=1;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="220" y="160" width="40" height="80" as="geometry" />
        </mxCell>
        <mxCell id="feishu" value="飞书开放平台 / Feishu Open Platform&#10;&#10;• OAuth 登录 / login&#10;• 审批卡片 / approval cards&#10;• WS 长连接回调（card.action.trigger）&#10;  WS callback — 免公网 / no public ingress" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="320" width="220" height="160" as="geometry" />
        </mxCell>

        <!-- ===== Lane: EC2 ===== -->
        <mxCell id="lane_ec2" value="② 生产 EC2 (kiro-v2.service / systemd, IAM Role: kiro-v2-ec2-role)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="360" y="110" width="430" height="600" as="geometry" />
        </mxCell>

        <mxCell id="frontend" value="前端 / Frontend&#10;React + TS + AntD&#10;（构建产物进 backend/static）&#10;build → backend/static" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="160" width="180" height="90" as="geometry" />
        </mxCell>

        <mxCell id="backend" value="后端 / Backend — FastAPI (uvicorn :8000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6C8EBF;align=center;verticalAlign=top;fontStyle=1;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="280" width="370" height="400" as="geometry" />
        </mxCell>
        <mxCell id="b_auth" value="auth / feishu — OAuth + JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="315" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b_ws" value="feishu_ws — WS 长连接&#10;先 ACK 后异步 / ACK then async" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="585" y="315" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b_router" value="routers — request / admin (14 API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="370" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b_approval" value="approval — 审批引擎&#10;抢占防重 + 异步执行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="585" y="370" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b_prov" value="provisioner — 开通/升级/退订/查询&#10;provision / upgrade / cancel / query&#10;（幂等 + 429 退避 / idempotent + backoff）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="405" y="430" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b_mapping" value="mapping_store — DynamoDB 映射层&#10;PK=kiro_user_id, GSI=feishu_open_id（1:N 主/副）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="505" width="340" height="45" as="geometry" />
        </mxCell>
        <mxCell id="b_usage" value="usage — Athena 用量查询（5min TTL 缓存）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="405" y="565" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="b_aws" value="aws — 凭证唯一出口 / sole credential source（IAM Role，无 AK/SK / no static keys）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="405" y="620" width="340" height="45" as="geometry" />
        </mxCell>

        <!-- ===== Lane: AWS services ===== -->
        <mxCell id="lane_aws" value="③ AWS 服务 / AWS Services (us-east-1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="830" y="110" width="340" height="600" as="geometry" />
        </mxCell>

        <mxCell id="idc" value="IAM Identity Center (IDC)&#10;d-906634fffc&#10;• CreateUser / 加组 / 密码邮件&#10;  create user / add group / password email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="160" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="kiro" value="Kiro 订阅 / Subscription&#10;q:CreateAssignment（由 q 服务代理 / proxied by q）&#10;级联 sso/sso-directory/user-subscriptions&#10;cascades into sso/... — 见 §5 IAM 坑&#10;tier: KIRO_ENTERPRISE_PRO / _PRO_PLUS / _PRO_MAX / _POWER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="275" width="280" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ddb" value="DynamoDB&#10;kiro-account-mapping (+ -requests)&#10;唯一真相源 / source of truth" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffffff;strokeColor=#82B366;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="415" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="athena" value="Athena + Glue + S3&#10;Kiro Analytics 用量看板 / usage dashboard&#10;DB=kiro-user-report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="525" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ses" value="密码设置邮件 / Password email&#10;sso-directory:UpdatePassword" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82B366;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="625" width="280" height="55" as="geometry" />
        </mxCell>

        <!-- ===== Lane: Ops ===== -->
        <mxCell id="lane_ops" value="④ 运维 / Ops（纯 API，无 SSH / no SSH）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="280" height="370" as="geometry" />
        </mxCell>
        <mxCell id="ssm" value="SSM send-command&#10;远程运维 / remote ops&#10;（base64 传脚本 + sudo -u ec2-user）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="600" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="ssmparam" value="SSM Parameter Store&#10;/kiro-v2/env (SecureString, KMS)&#10;→ 部署时拉到 backend/.env&#10;pulled to backend/.env on deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="690" width="220" height="85" as="geometry" />
        </mxCell>
        <mxCell id="github" value="GitHub (private)&#10;Sm1-z/kiro-feishu-account-bot&#10;Deploy Key（只读 / read-only）&#10;更新：git reset --hard origin/main&#10;（历史重写过，不能 pull）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="790" width="220" height="100" as="geometry" />
        </mxCell>
        <mxCell id="cloudtrail" value="CloudTrail — 权限排查 / authz debug&#10;lookup-events（看 invokedBy）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="350" width="0" height="0" as="geometry" />
        </mxCell>

        <!-- ===== Flows ===== -->
        <!-- user -> frontend (login/apply) -->
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=1;strokeColor=#6c8ebf;fontSize=10;" edge="1" parent="1" source="user" target="frontend">
