        </mxCell>
        <mxCell id="e1lbl" value="1. 登录/申请&#10;login / apply" style="text;html=1;fontSize=10;fillColor=#ffffff;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="180" y="108" width="90" height="28" as="geometry" />
        </mxCell>

        <!-- frontend <-> feishu OAuth -->
        <mxCell id="e2" style="endArrow=classic;startArrow=classic;html=1;rounded=1;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="b_auth" target="feishu">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2lbl" value="2. OAuth" style="text;html=1;fontSize=10;fillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="300" y="335" width="60" height="20" as="geometry" />
        </mxCell>

        <!-- backend -> feishu send card -->
        <mxCell id="e3" style="endArrow=classic;html=1;rounded=1;strokeColor=#82b366;exitX=0;exitY=0.5;exitDx=0;exitDy=0;fontSize=10;" edge="1" parent="1" source="b_approval" target="feishu">
