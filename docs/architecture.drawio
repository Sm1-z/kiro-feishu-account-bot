        <!-- Legend -->
        <mxCell id="legend" value="图例 / Legend&#10;━━ 实线：运行时调用 / runtime call&#10;┈┈ 虚线：配置/部署/凭证 / config·deploy·creds&#10;橙色：开通核心链路 / provisioning core&#10;红色：安全基线（IAM Role，无密钥）/ security baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=11;" vertex="1" parent="1">
