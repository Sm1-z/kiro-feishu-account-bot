        <mxCell id="e3lbl" value="3. 推审批卡片&#10;push card" style="text;html=1;fontSize=10;fillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="300" y="392" width="80" height="28" as="geometry" />
        </mxCell>

        <!-- feishu -> ws callback (approve) -->
        <mxCell id="e4" style="endArrow=classic;html=1;rounded=1;strokeColor=#82b366;dashed=1;fontSize=10;" edge="1" parent="1" source="feishu" target="b_ws">
