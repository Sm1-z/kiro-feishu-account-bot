        <mxCell id="e6lbl" value="5a. 建用户/加组&#10;create user/group" style="text;html=1;fontSize=10;fillColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="760" y="225" width="100" height="28" as="geometry" />
