          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7lbl" value="5b. 订阅 / subscribe&#10;q:CreateAssignment" style="text;html=1;fontSize=10;fillColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="300" width="100" height="28" as="geometry" />
        </mxCell>

        <!-- provisioner -> ses -->
