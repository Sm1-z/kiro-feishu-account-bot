{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IdentityStoreUserAndGroup",
      "Effect": "Allow",
      "Action": [
        "identitystore:CreateUser",
        "identitystore:DescribeUser",
        "identitystore:GetUserId",
        "identitystore:ListUsers",
        "identitystore:DeleteUser",
        "identitystore:CreateGroupMembership",
        "identitystore:GetGroupId",
        "identitystore:ListGroups",
        "identitystore:ListGroupMembershipsForMember"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SsoAdminAppAndAssignment",
      "Effect": "Allow",
      "Action": [
        "sso:ListInstances",
        "sso:DescribeApplication",
        "sso:ListApplications",
        "sso:CreateApplicationAssignment",
        "sso:DeleteApplicationAssignment",
        "sso:ListApplicationAssignments"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SsoDirectoryPasswordReset",
      "Effect": "Allow",
      "Action": ["sso-directory:UpdatePassword"],
      "Resource": "*"
    },
    {
      "Sid": "KiroSubscription",
      "Effect": "Allow",
      "Action": [
        "q:CreateAssignment",
        "q:UpdateAssignment",
        "q:DeleteAssignment",
        "user-subscriptions:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DynamoDBMappingTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:*:*:table/kiro-account-mapping",
        "arn:aws:dynamodb:*:*:table/kiro-account-mapping/index/*",
        "arn:aws:dynamodb:*:*:table/kiro-account-mapping-requests",
        "arn:aws:dynamodb:*:*:table/kiro-account-mapping-requests/index/*"
      ]
    },
    {
      "Sid": "KiroUsageAnalyticsRead",
      "Effect": "Allow",
      "Action": [
        "athena:StartQueryExecution",
        "athena:GetQueryExecution",
        "athena:GetQueryResults",
        "athena:StopQueryExecution",
        "glue:GetTable",
        "glue:GetTables",
        "glue:GetDatabase",
        "glue:GetPartitions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KiroUsageAnalyticsS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::kiro-user-activity-*",
        "arn:aws:s3:::kiro-user-activity-*/*",
        "arn:aws:s3:::kiro-user-report-dashboard-athena-results-*",
        "arn:aws:s3:::kiro-user-report-dashboard-athena-results-*/*"
      ]
    }
  ]
}
